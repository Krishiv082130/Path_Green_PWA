@page
@model Path_Green.web.Pages.Schools.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1 class="fw-bold text-danger mb-3">Delete School</h1>

<p class="text-muted">
    Confirm that you want to remove this school from the system.
</p>
<div>
    <h4>School</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.School.SchoolName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.School.SchoolName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.School.IsActive)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.School.IsActive)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="School.SchoolID" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-outline-secondary ms-2">
            Cancel
        </a>
    </form>
</div>

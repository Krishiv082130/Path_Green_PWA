@page
@model Path_Green.web.Pages.Schools.DetailsModel

@{
    ViewData["Title"] = "Details";
}

                    <h1 class="fw-bold mb-3">School Details</h1>
<div>
    <h4>School</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.School.SchoolName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.School.SchoolName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.School.IsActive)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.School.IsActive)
        </dd>
    </dl>
</div>
<div>
   <a asp-page="./Edit"
   asp-route-id="@Model.School.SchoolID"
   class="btn btn-primary">
    Edit
</a>

<a asp-page="./Index"
   class="btn btn-outline-secondary ms-2">
    Back
</a>
</div>
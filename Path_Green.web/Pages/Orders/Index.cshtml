@page
@model Path_Green.web.Pages.Orders.IndexModel

<h2>Manage Orders</h2>

<form method="get" class="card shadow-sm border-0 mb-4">
    <div class="card-body">

        <div class="row g-3 align-items-end">

            <div class="col-md-4">
                <label class="form-label">Search Orders</label>
                <input type="text"
                       name="SearchString"
                       value="@Model.SearchString"
                       class="form-control"
                       placeholder="Order ID, Student ID, school, product..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Order Date</label>
                <input type="date"
                       name="OrderDateSearch"
                       value="@(Model.OrderDateSearch?.ToString("yyyy-MM-dd"))"
                       class="form-control" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="StatusFilter" class="form-select">
                    <option value="All" selected="@(Model.StatusFilter == "All" || string.IsNullOrEmpty(Model.StatusFilter))">
                        All Orders
                    </option>
                    <option value="Pending" selected="@(Model.StatusFilter == "Pending")">
                        Pending
                    </option>
                    <option value="Approved" selected="@(Model.StatusFilter == "Approved")">
                        Approved
                    </option>
                    <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">
                        Rejected
                    </option>
                    <option value="Delivered" selected="@(Model.StatusFilter == "Delivered")">
                        Delivered
                    </option>
                </select>
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">
                    Search
                </button>

                <a asp-page="./Index" class="btn btn-outline-secondary">
                    Clear
                </a>
            </div>

        </div>

    </div>
</form>

@if (!Model.Orders.Any())
{
    <div class="alert alert-info">
        No orders found for the selected search criteria.
    </div>
}

@foreach (var order in Model.Orders)
{
    <div class="card shadow border-0 mb-4">

        <!-- HEADER -->
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap">

            <div>
                <strong>Order ID:</strong> @order.OrderID
            </div>

            <div>
                <strong>Date:</strong> @order.OrderDate
            </div>

            <div>
                <strong>Status:</strong>

                @if (order.OrderStatus?.StatusName == "Pending")
                {
                    <span class="badge bg-warning text-dark">Pending</span>
                }
                else if (order.OrderStatus?.StatusName == "Approved")
                {
                    <span class="badge bg-success">Approved</span>
                }
                else if (order.OrderStatus?.StatusName == "Delivered")
                {
                    <span class="badge bg-dark">Delivered</span>
                }
                else if (order.OrderStatus?.StatusName == "Rejected")
                {
                    <span class="badge bg-danger">Rejected</span>
                }
            </div>

            <div>
                <strong>Items:</strong> @(order.OrderItems?.Count ?? 0)
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary btn-sm"
                        type="button"
                        onclick="toggleDetails(@order.OrderID)">
                    View Details
                </button>

                <button class="btn btn-outline-primary btn-sm"
                        type="button"
                        onclick="toggleProducts(@order.OrderID)">
                    View Products
                </button>
            </div>

        </div>

        <!-- BODY -->
        <div class="card-body">

            <!-- DETAILS SECTION -->
            <div id="details-@order.OrderID"
                 style="display:none;">

                <h5 class="border-bottom pb-2 mb-3">
                    Student Information
                </h5>

                <div class="row">

                    <div class="col-md-6">
                        <p><strong>Student ID:</strong> @order.StudentID</p>
                        <p><strong>School:</strong> @order.SchoolName</p>
                        <p><strong>Grade Level:</strong> @order.GradeLevel</p>
                        <p><strong>Ethnicity:</strong> @order.Ethnicity</p>
                    </div>

                    <div class="col-md-6">
                        <p><strong>Hair Type:</strong> @order.HairType</p>
                        <p><strong>Hair Length:</strong> @order.HairLength</p>
                        <p><strong>Skin Type:</strong> @order.SkinType</p>
                        <p><strong>Allergies:</strong> @order.Allergies</p>
                    </div>

                </div>

                <h5 class="border-bottom pb-2 mb-3 mt-4">
                    Notes
                </h5>

                <p>@order.Notes</p>

            </div>

            <!-- STATUS UPDATE -->
            <div class="d-flex align-items-center gap-2 mt-3 flex-wrap">

                <form method="post" asp-page-handler="UpdateStatus" class="d-flex gap-2">

                    <input type="hidden"
                           name="OrderID"
                           value="@order.OrderID" />

                    <select name="StatusName" class="form-select form-select-sm">

                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                        <option value="Delivered">Delivered</option>

                    </select>

                    <button type="submit"
                            class="btn btn-outline-primary btn-sm">
                        Update
                    </button>

                </form>

                @if (order.OrderStatus != null &&
                            (order.OrderStatus.StatusName == "Pending" ||
                            order.OrderStatus.StatusName == "Rejected"))
                {
                    <form method="post"
                          asp-page-handler="DeleteOrder"
                          onsubmit="return confirm('Are you sure you want to delete this order?');">

                        <input type="hidden"
                               name="OrderID"
                               value="@order.OrderID" />

                        <button type="submit"
                                class="btn btn-danger btn-sm">
                            Delete
                        </button>

                    </form>
                }

            </div>

            <!-- PRODUCTS SECTION -->
            <div id="products-@order.OrderID"
                 style="display:none;">

                <h5 class="border-bottom pb-2 mb-3 mt-4">
                    Selected Products
                </h5>

                <ul class="list-group">

                    @foreach (var item in order.OrderItems!)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">

                            <span>
                                @item.Product?.ProductName
                            </span>

                        </li>
                    }

                </ul>

            </div>

        </div>

    </div>
}
<script>
    function toggleDetails(orderId) {
        var section = document.getElementById("details-" + orderId);

        if (section.style.display === "none") {
            section.style.display = "block";
        } else {
            section.style.display = "none";
        }
    }

    function toggleProducts(orderId) {
        var section = document.getElementById("products-" + orderId);

        if (section.style.display === "none") {
            section.style.display = "block";
        } else {
            section.style.display = "none";
        }
    }
</script>
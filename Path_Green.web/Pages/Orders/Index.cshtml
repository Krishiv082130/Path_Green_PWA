@page
@model Path_Green.web.Pages.Orders.IndexModel

<h2>My Orders</h2>

<form method="get" class="mb-3">
    <label class="form-label">Filter by Status</label>

    <select name="StatusFilter" class="form-select" onchange="this.form.submit()">
        <option value="All" selected="@(Model.StatusFilter == "All" || string.IsNullOrEmpty(Model.StatusFilter))">All Orders</option>
        <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
        <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
        <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
        <option value="Delivered" selected="@(Model.StatusFilter == "Delivered")">Delivered</option>
    </select>
</form>

@foreach (var order in Model.Orders)
{
    <div style="border:1px solid gray; margin:10px; padding:10px;">
        <p><strong>Order ID:</strong> @order.OrderID</p>
        <p><strong>Date:</strong> @order.OrderDate</p>
        <p><strong>Total:</strong> @order.TotalAmount</p>
        <p><strong>Status:</strong> @order.OrderStatus?.StatusName</p>

        <form method="post" asp-page-handler="UpdateStatus">
            <input type="hidden" name="OrderID" value="@order.OrderID" />

            <select name="StatusName">
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Rejected">Rejected</option>
                <option value="Delivered">Delivered</option>
            </select>

            <button type="submit">Update</button>
        </form>

        @if (order.OrderStatus != null &&
            (order.OrderStatus.StatusName == "Pending" || order.OrderStatus.StatusName == "Rejected"))
        {
            <form method="post" asp-page-handler="DeleteOrder" class="d-inline"
                  onsubmit="return confirm('Are you sure you want to delete this order? This cannot be undone.');">
                <input type="hidden" name="OrderID" value="@order.OrderID" />
                <button type="submit" class="btn btn-sm btn-danger">
                    Delete
                </button>
            </form>
        }

        <h4>Items:</h4>
        <ul>
            @foreach (var item in order.OrderItems!)
            {
                <li>
                    @item.Product?.ProductName -
                    Qty: @item.Quantity -
                    $@item.LineTotal
                </li>
            }
        </ul>
    </div>
}
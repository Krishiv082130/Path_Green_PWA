@page
@model Path_Green.web.Pages.Orders.CreateStep2Model

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-10">

<div class="mb-4">
    <h2>Place Hygiene Order</h2>

    <div class="alert alert-info">
        Step 2 of 2 — Product Selection
    </div>
</div>

<form method="post" onsubmit="return validateForm()">

    <!-- Hidden fields (carries Step 1 data) -->
    <input type="hidden" asp-for="StudentID" />
    <input type="hidden" asp-for="SchoolName" />
    <input type="hidden" asp-for="FirstName" />
    <input type="hidden" asp-for="LastName" />
    <input type="hidden" asp-for="GradeLevel" />
    <input type="hidden" asp-for="Ethnicity" />
    <input type="hidden" asp-for="HairType" />
    <input type="hidden" asp-for="HairLength" />
    <input type="hidden" asp-for="SkinType" />
    <input type="hidden" asp-for="Allergies" />
    <input type="hidden" asp-for="Notes" />

    @foreach (var category in Model.GroupedProducts)
    {
         <div class="card mb-4 shadow-sm">

             <div class="card-header bg-primary text-white">
                 <h4 class="mb-0">@category.Key</h4>
             </div>

      <div class="card-body">

            @foreach (var subCategory in category.Value)
            {
                <div class="form-check ms-4 mb-2">

                      <h5 class="mt-3 text-primary border-bottom pb-2">
                          @subCategory.Key
                      </h5>

                    @foreach (var product in subCategory.Value)
                    {
                        <div style="margin-left:20px;">
                            <input type="checkbox"
                                   name="SelectedProductIDs"
                                   value="@product.ProductID"
                                   class="form-check-input product-checkbox"
                                   data-category="@category.Key"
                                   data-name="@product.ProductName"
                                   disabled="@(product.Inventory != null && product.Inventory.QuantityOnHand <= 0)" />

                                <label class="form-check-label">

                                                @product.ProductName

                                </label>
                                @if (product.Inventory != null &&
                                     product.Inventory.QuantityOnHand <= 0)
                                {
                                   <span class="badge bg-danger ms-2">
                                        Out of Stock
                                   </span>
                                }
                                
                        </div>
                    }

                </div>
            }

        </div>
     
      </div>
    }

    <div class="mt-4">

        <a asp-page="/Orders/CreateStep1"
           asp-route-FirstName="@Model.FirstName"
           asp-route-LastName="@Model.LastName"
           asp-route-GradeLevel="@Model.GradeLevel"
           asp-route-Ethnicity="@Model.Ethnicity"
           asp-route-HairType="@Model.HairType"
           asp-route-HairLength="@Model.HairLength"
           asp-route-SkinType="@Model.SkinType"
           asp-route-Allergies="@Model.Allergies"
           asp-route-Notes="@Model.Notes"
           class="btn btn-secondary">
            ← Back
        </a>

        <button type="submit"
                class="btn btn-success">
            Submit Order
        </button>

    </div>

</form>

<!-- JavaScript for enforcing selection rules -->

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const checkboxes = document.querySelectorAll(".product-checkbox");

        function isChecked(name) {
            return Array.from(checkboxes).some(cb => cb.dataset.name === name && cb.checked);
        }

        function getCheckboxByName(name) {
            return Array.from(checkboxes).find(cb => cb.dataset.name === name);
        }

        checkboxes.forEach(cb => {
            cb.addEventListener("change", function () {

                const category = this.dataset.category;
                const name = this.dataset.name;

                const sameCategory = document.querySelectorAll(
                    `.product-checkbox[data-category='${category}']`
                );
                const checked = Array.from(sameCategory).filter(c => c.checked);

                    if (category !== "Luxury") {

        // Shampoo special case
            if (category === "Shampoo") {

            const nonCoWashChecked = checked.filter(c =>
                !c.dataset.name.includes("Co-Wash")
            );

            if (nonCoWashChecked.length > 1) {
                alert("Only ONE shampoo option allowed");
                this.checked = false;
                return;
            }

            }
          else {

            if (checked.length > 1) {
                alert("Only ONE item allowed in " + category);
                this.checked = false;
                return;
            }

        }
    }

                if (category === "Luxury" && checked.length > 5) {
                    alert("Max 5 Luxury items");
                    this.checked = false;
                    return;
                }

                // ===== RULE 1: Conditioner depends on Shampoo =====

                if (name.includes("3c-4c Conditioner")) {
                    if (!isChecked("3c-4c Shampoo")) {
                        alert("You must select 3c-4c Shampoo first");
                        this.checked = false;
                        return;
                    }
                }

                // Enable Co-Wash ONLY if 3c-4c shampoo selected
                const coWash = getCheckboxByName("Co-Wash for Type 4a-c");

                if (coWash) {
                    coWash.disabled = !isChecked("3c-4c Shampoo");
                    if (!isChecked("3c-4c Shampoo")) {
                        coWash.checked = false;
                    }
                }
            

            });
        });

    });
</script>

<script>
    function validateForm() {

        const allChecked = document.querySelectorAll(".product-checkbox:checked");

        if (allChecked.length === 0) {
            alert("Please select at least one item.");
            return false;
        }

        return true;
    }
</script>
        </div>

    </div>

</div>
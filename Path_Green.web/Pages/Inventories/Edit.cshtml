@page
@model Path_Green.web.Pages.Inventories.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Inventory</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Inventory.InventoryID" />
            <div class="form-group">
                <label asp-for="Inventory.ProductID" class="control-label"></label>
                <select asp-for="Inventory.ProductID" class="form-control" asp-items="ViewBag.ProductID" ></select>
                <span asp-validation-for="Inventory.ProductID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Inventory.QuantityOnHand" class="control-label"></label>
                <input asp-for="Inventory.QuantityOnHand" class="form-control" />
                <span asp-validation-for="Inventory.QuantityOnHand" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Inventory.ReorderLevel" class="control-label"></label>
                <input asp-for="Inventory.ReorderLevel" class="form-control" />
                <span asp-validation-for="Inventory.ReorderLevel" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary mt-4" />
                <a asp-page="./Index" class="btn btn-outline-secondary mt-4 ms-2">
                    Back
                </a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

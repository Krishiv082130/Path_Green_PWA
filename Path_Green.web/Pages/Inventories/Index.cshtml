@page
@model Path_Green.web.Pages.Inventories.IndexModel

@{
    ViewData["Title"] = "Index";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold">
                Inventory Management
            </h1>

            <p class="text-muted">
                Monitor stock levels and reorder alerts.
            </p>
        </div>

        <a asp-page="Create"
           class="btn btn-primary">
            + Add Inventory
        </a>

    </div>

    <form method="get" class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <div class="row g-3 align-items-end">

                <div class="col-md-5">
                    <label class="form-label">Search Inventory</label>
                    <input type="text"
                           name="SearchString"
                           value="@Model.SearchString"
                           class="form-control"
                           placeholder="Search by product name..." />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Stock Filter</label>
                    <select name="StockFilter" class="form-select">
                        <option value="All" selected="@(Model.StockFilter == "All" || string.IsNullOrEmpty(Model.StockFilter))">
                            All Items
                        </option>
                        <option value="LowStock" selected="@(Model.StockFilter == "LowStock")">
                            Low Stock
                        </option>
                        <option value="OutOfStock" selected="@(Model.StockFilter == "OutOfStock")">
                            Out of Stock
                        </option>
                    </select>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        Search
                    </button>

                    <a asp-page="./Index" class="btn btn-outline-secondary">
                        Clear
                    </a>
                </div>

            </div>

        </div>
    </form>

    @if (!Model.Inventory.Any())
    {
        <div class="alert alert-info">
            No inventory items found for the selected search criteria.
        </div>
    }

<table class="table table-hover align-middle shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>
                Product
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Inventory[0].QuantityOnHand)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Inventory[0].ReorderLevel)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Inventory[0].LastUpdated)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Inventory) {
        
        <tr class="@(item.QuantityOnHand <= 0 ? "table-danger" : item.QuantityOnHand <= item.ReorderLevel ? "table-warning" : "")">
            <td>
                @item.Product?.ProductName
            </td>
            <td>

                        @if (item.QuantityOnHand <= 0)
                        {
                            <span class="badge bg-danger">
                                Out of Stock
                            </span>
                        }
                        else if (item.QuantityOnHand <= item.ReorderLevel)
                        {
                            <span class="badge bg-warning text-dark">
                                Low Stock (@item.QuantityOnHand)
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                @item.QuantityOnHand In Stock
                            </span>
                        }

            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReorderLevel)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastUpdated)
            </td>
            <td>
               <div class="d-flex gap-2">
                <a asp-page="./Edit" asp-route-id="@item.InventoryID" class="btn btn-sm btn-outline-primary"> Edit</a>
                <a asp-page="./Details" asp-route-id="@item.InventoryID" class="btn btn-sm btn-outline-secondary"> Details </a>
                <a asp-page="./Delete" asp-route-id="@item.InventoryID" class="btn btn-sm btn-outline-danger"> Delete </a>
               </div>
            </td>
        </tr>
}
    </tbody>
</table>
</div>

@page
@model Path_Green.web.Pages.Products.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<div style="color:red">
    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
    {
        <p>@error.ErrorMessage</p>
    }
</div>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Products[0].ProductName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Products[0].Category)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Products[0].Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Products[0].UnitPrice)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Products[0].UnitType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Products[0].IsActive)
            </th>
            <th>Order</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Products) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ProductName)
            </td>
            <td>
                    @item.Category
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UnitPrice)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UnitType)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsActive)
            </td>
             <td>
                    <form method="post" asp-page-handler="AddToOrder">
                        <input type="hidden" name="ProductID" value="@item.ProductID" />

                        <input type="number" name="Quantity" value="1" min="1" style="width:60px;" />

                        <div class="mb-2">
                            <input name="FirstName" class="form-control" placeholder="First Name" required />
                        </div>

                        <div class="mb-2">
                            <input name="LastName" class="form-control" placeholder="Last Name" required />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Grade Level</label>
                            <select name="GradeLevel" class="form-control" required>
                                <option value="">Choose grade level</option>
                                <option value="9th">9th</option>
                                <option value="10th">10th</option>
                                <option value="11th">11th</option>
                                <option value="12th">12th</option>
                            </select>
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Ethnicity</label>
                            <select name="Ethnicity" class="form-control" required>
                                <option value="">Choose ethnicity</option>
                                <option value="Black/African">Black/African</option>
                                <option value="Caucasian/White">Caucasian/White</option>
                                <option value="Hispanic/Latina">Hispanic/Latina</option>
                                <option value="Asian">Asian</option>
                                <option value="Mixed">Mixed</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Hair Type</label>
                            <select name="HairType" class="form-control" required>
                                <option value="">Choose hair type</option>

                                <option value="1a - Straight, thin, silky, keeps strands flat">
                                    1a - Straight, thin, silky, keeps strands flat
                                </option>

                                <option value="1b - Straight with slight bends/coarser strands">
                                    1b - Straight with slight bends/coarser strands
                                </option>

                                <option value="1c - Straight, thicker/coarser, prone to frizz">
                                    1c - Straight, thicker/coarser, prone to frizz
                                </option>

                                <option value="2a - Loose wave, fine/medium, S-shape pattern">
                                    2a - Loose wave, fine/medium, S-shape pattern
                                </option>

                                <option value="2b - More defined S-waves, prone to frizz">
                                    2b - More defined S-waves, prone to frizz
                                </option>

                                <option value="2c - Strong waves, loose curls, coarse texture">
                                    2c - Strong waves, loose curls, coarse texture
                                </option>

                                <option value="3a - Loose curls, wide curl pattern">
                                    3a - Loose curls, wide curl pattern
                                </option>

                                <option value="3b - Bouncy curls, tighter than 3a">
                                    3b - Bouncy curls, tighter than 3a
                                </option>

                                <option value="3c - Tight curls, dense/coily texture">
                                    3c - Tight curls, dense/coily texture
                                </option>

                                <option value="4a - Tight S-shaped coils">
                                    4a - Tight S-shaped coils
                                </option>

                                <option value="4b - Sharp Z-shaped coils, less defined curl pattern">
                                    4b - Sharp Z-shaped coils, less defined curl pattern
                                </option>

                                <option value="4c - Tight Z-shaped coils, most delicate/natural hair type">
                                    4c - Tight Z-shaped coils, most delicate/natural hair type
                                </option>
                            </select>
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Length of Hair</label>
                            <select name="HairLength" class="form-control" required>
                                <option value="">Choose hair length</option>
                                <option value="Super Short - Hair length is above the ears">
                                    Super Short - Hair length is above the ears
                                </option>
                                <option value="Short - Hair length only goes to the chin">
                                    Short - Hair length only goes to the chin
                                </option>
                                <option value="Medium - Hair length is longer than chin but not past shoulders">
                                    Medium - Hair length is longer than chin but not past shoulders
                                </option>
                                <option value="Long - Hair length is past the shoulders">
                                    Long - Hair length is past the shoulders
                                </option>
                            </select>
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Skin Type</label>
                            <select name="SkinType" class="form-control" required>
                                <option value="">Choose skin type</option>

                                <option value="Oily Skin - Shiny/greasy skin, often larger pores and acne prone">
                                    Oily Skin - Shiny/greasy skin, often larger pores and acne prone
                                </option>

                                <option value="Dry Skin - Rough, flaky, tight, less elastic, may itch or irritate">
                                    Dry Skin - Rough, flaky, tight, less elastic, may itch or irritate
                                </option>

                                <option value="Combination Skin - Oily T-zone with dry/normal cheeks">
                                    Combination Skin - Oily T-zone with dry/normal cheeks
                                </option>

                                <option value="Sensitive Skin - Easily irritated, red, burning, itching, or reactive">
                                    Sensitive Skin - Easily irritated, red, burning, itching, or reactive
                                </option>
                            </select>
                        </div>

                        <div class="mb-2">
                            <input name="Allergies" class="form-control" placeholder="Allergies" />
                        </div>

                        <button type="submit">Add</button>
                    </form>
             </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.ProductID">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.ProductID">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.ProductID">Delete</a>
            </td>
                
        </tr>
}
    </tbody>
</table>

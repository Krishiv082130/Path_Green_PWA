@page
@model Path_Green.web.Pages.Products.IndexModel

@{
    ViewData["Title"] = "Index";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold">Manage Products</h1>
            <p class="text-muted">
                Add, update, and organize products by category and subcategory.
            </p>
        </div>

        <a asp-page="Create" class="btn btn-primary">
            + Add Product
        </a>

    </div>

    <form method="get" class="mb-4">
        <div class="input-group">
            <input type="text"
                   name="SearchString"
                   value="@Model.SearchString"
                   class="form-control"
                   placeholder="Search by product name, category, or subcategory..." />

            <button type="submit" class="btn btn-primary">
                Search
            </button>

            <a asp-page="./Index" class="btn btn-outline-secondary ms-2">
                Clear
            </a>
        </div>
    </form>

<div style="color:red">
    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
    {
        <p>@error.ErrorMessage</p>
    }
</div>

<table class="table table-hover align-middle shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Products[0].ProductName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Products[0].Category)
            </th>
            <th>
                SubCategory
            </th>
                <th>
                   
                </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Products) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ProductName)
            </td>
            <td>
                    @item.Category
            </td>
            <td>
                    @item.SubCategory
            </td>
             <td>
                  @*old add order form goes here*@  
            <td>
                <div class="d-flex gap-2">

                            <a asp-page="./Edit"
                               asp-route-id="@item.ProductID"
                               class="btn btn-sm btn-outline-primary">
                                Edit
                            </a>

                            <a asp-page="./Details"
                               asp-route-id="@item.ProductID"
                               class="btn btn-sm btn-outline-secondary">
                                Details
                            </a>

                            <a asp-page="./Delete"
                               asp-route-id="@item.ProductID"
                               class="btn btn-sm btn-outline-danger">
                                Delete
                            </a>

                </div>
            </td>
                
        </tr>
}
    </tbody>
</table>
</div>
